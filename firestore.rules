rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentIdentifier() {
      return isSignedIn() &&
          exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid))
          ? get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.identifierUpper
          : null;
    }

    function isSessionMember(data) {
      return (data.memberUids is list && request.auth.uid in data.memberUids) ||
        (currentIdentifier() != null &&
          data.memberIdentifiers is list &&
          currentIdentifier() in data.memberIdentifiers);
    }

    match /shared_sessions/{sessionId} {
      allow read: if isSignedIn() && isSessionMember(resource.data);

      allow create: if isSignedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        isSessionMember(request.resource.data);

      allow update, delete: if isSignedIn() &&
        resource.data.ownerUid == request.auth.uid;
    }

    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }
  }
}
